@model RoomBCS240032
@using Lesson3_CNLTWeb.Models;

@{
    ViewData["Title"] = $"Xóa phòng {Model.Name}";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>

            <div class="alert alert-danger" role="alert">
                <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa phòng này? Hành động này không thể hoàn tác.
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Thông tin phòng</h5>
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Tên phòng:</strong></td>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Loại phòng:</strong></td>
                            <td>@Model.RoomType?.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Giá thuê:</strong></td>
                            <td>@Model.Price.ToString("N0") VNĐ</td>
                        </tr>
                        <tr>
                            <td><strong>Diện tích:</strong></td>
                            <td>@Model.Area.ToString("F2") m²</td>
                        </tr>
                        <tr>
                            <td><strong>Trạng thái:</strong></td>
                            <td>
                                @if (Model.IsAvailable)
                                {
                                    <span class="badge badge-success">Còn phòng</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Hết phòng</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
                <button type="submit" class="btn btn-danger">Xóa phòng này</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>
</div>
