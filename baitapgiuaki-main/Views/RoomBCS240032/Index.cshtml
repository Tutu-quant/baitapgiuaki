@model List<RoomBCS240032>
@using Lesson3_CNLTWeb.Models;

@{
    ViewData["Title"] = "Danh sách phòng cho thuê";
    var availableCount = Model.Count(room => room.IsAvailable);
}

<section class="page-hero">
    <div>
        <div class="page-kicker">Quản lý phòng</div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">Theo dõi thông tin phòng, giá thuê, diện tích và trạng thái còn trống.</p>
    </div>
    <div class="stat-strip">
        <div class="stat-item">
            <span class="stat-value">@ViewBag.TotalItems</span>
            <span class="stat-label">Tổng phòng</span>
        </div>
        <div class="stat-item">
            <span class="stat-value">@availableCount</span>
            <span class="stat-label">Đang còn</span>
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["ErrorMessage"]?.ToString()))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["WarningMessage"]?.ToString()))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<section class="content-panel">
    <form asp-action="Index" method="get" class="filter-grid">
        <div>
            <label for="searchName" class="form-label">Tên phòng</label>
            <input type="text" id="searchName" name="searchName" class="form-control"
                   value="@ViewBag.SearchName" placeholder="Nhập tên phòng">
        </div>

        <div>
            <label for="roomTypeId" class="form-label">Loại phòng</label>
            <select id="roomTypeId" name="roomTypeId" class="form-select">
                <option value="">Tất cả</option>
                @foreach (var roomType in ViewBag.RoomTypes)
                {
                    <option value="@roomType.Value" selected="@(roomType.Selected)">@roomType.Text</option>
                }
            </select>
        </div>

        <div>
            <label for="isAvailable" class="form-label">Trạng thái</label>
            <select id="isAvailable" name="isAvailable" class="form-select">
                <option value="">Tất cả</option>
                <option value="true" selected="@(ViewBag.IsAvailable == true)">Còn phòng</option>
                <option value="false" selected="@(ViewBag.IsAvailable == false)">Hết phòng</option>
            </select>
        </div>

        <div>
            <label for="maxPrice" class="form-label">Giá tối đa</label>
            <input type="number" id="maxPrice" name="maxPrice" class="form-control"
                   value="@ViewBag.MaxPrice" placeholder="VNĐ" min="0" step="100000">
        </div>

        <div>
            <label for="sortBy" class="form-label">Sắp xếp</label>
            <select id="sortBy" name="sortBy" class="form-select">
                <option value="default" selected="@(ViewBag.SortBy == "default" || string.IsNullOrEmpty(ViewBag.SortBy))">Mặc định</option>
                <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Giá tăng dần</option>
                <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Giá giảm dần</option>
                <option value="area_desc" selected="@(ViewBag.SortBy == "area_desc")">Diện tích giảm dần</option>
            </select>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
    </form>
</section>

<section class="content-panel">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
        <div>
            <strong>Kết quả: @ViewBag.TotalItems phòng</strong>
            @if (ViewBag.TotalItems > 0)
            {
                <span class="text-muted"> | Trang @ViewBag.CurrentPage/@ViewBag.TotalPages</span>
            }
        </div>
        <div class="action-row">
            <a href="@Url.Action("Create")" class="btn btn-success">+ Thêm phòng mới</a>
            <a href="@Url.Action("Index", "RoomTypeBCS240032")" class="btn btn-info">Quản lý loại phòng</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <h5>Không tìm thấy phòng phù hợp</h5>
            <p class="text-muted mb-0">Hãy đổi từ khóa, trạng thái hoặc khoảng giá để xem thêm kết quả.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ảnh</th>
                        <th>Tên phòng</th>
                        <th>Loại phòng</th>
                        <th class="text-end">Giá (VNĐ)</th>
                        <th class="text-end">Diện tích</th>
                        <th class="text-end">Giá/m²</th>
                        <th>Trạng thái</th>
                        <th>Mô tả</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var room in Model)
                    {
                        var thumbnail = room.RoomImages.FirstOrDefault(image => image.IsThumbnail)
                            ?? room.RoomImages.FirstOrDefault();

                        <tr>
                            <td>
                                @if (thumbnail != null)
                                {
                                    <img src="@thumbnail.ImageUrl" alt="Ảnh phòng @room.Name" class="room-thumb" loading="lazy">
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Chưa có ảnh</span>
                                }
                            </td>
                            <td><strong>@room.Name</strong></td>
                            <td>@room.RoomType?.Name</td>
                            <td class="text-end">@room.Price.ToString("N0")</td>
                            <td class="text-end">@room.Area.ToString("F2") m²</td>
                            <td class="text-end">@room.PricePerSquareMeter.ToString("N0")</td>
                            <td>
                                @if (room.IsAvailable)
                                {
                                    <span class="badge text-bg-success">Còn phòng</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger">Hết phòng</span>
                                }
                            </td>
                            <td class="description-cell">@(room.Description ?? "-")</td>
                            <td>
                                <div class="table-actions">
                                    <a href="@Url.Action("Details", new { id = room.Id })" class="btn btn-sm btn-info">Chi tiết</a>
                                    <a href="@Url.Action("Edit", new { id = room.Id })" class="btn btn-sm btn-warning">Sửa</a>
                                    <a href="@Url.Action("Delete", new { id = room.Id })" class="btn btn-sm btn-danger">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Phân trang" class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = 1, searchName = ViewBag.SearchName, roomTypeId = ViewBag.RoomTypeId, isAvailable = ViewBag.IsAvailable, maxPrice = ViewBag.MaxPrice, sortBy = ViewBag.SortBy })">Đầu</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, searchName = ViewBag.SearchName, roomTypeId = ViewBag.RoomTypeId, isAvailable = ViewBag.IsAvailable, maxPrice = ViewBag.MaxPrice, sortBy = ViewBag.SortBy })">Trước</a>
                        </li>
                    }

                    @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i, searchName = ViewBag.SearchName, roomTypeId = ViewBag.RoomTypeId, isAvailable = ViewBag.IsAvailable, maxPrice = ViewBag.MaxPrice, sortBy = ViewBag.SortBy })">@i</a>
                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, searchName = ViewBag.SearchName, roomTypeId = ViewBag.RoomTypeId, isAvailable = ViewBag.IsAvailable, maxPrice = ViewBag.MaxPrice, sortBy = ViewBag.SortBy })">Sau</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.TotalPages, searchName = ViewBag.SearchName, roomTypeId = ViewBag.RoomTypeId, isAvailable = ViewBag.IsAvailable, maxPrice = ViewBag.MaxPrice, sortBy = ViewBag.SortBy })">Cuối</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
