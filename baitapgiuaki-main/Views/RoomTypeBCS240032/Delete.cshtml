@model RoomTypeBCS240032
@using Lesson3_CNLTWeb.Models;

@{
    ViewData["Title"] = $"Xóa loại phòng {Model.Name}";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>

            <div class="alert alert-danger" role="alert">
                <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa loại phòng này? Hành động này không thể hoàn tác.
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Thông tin loại phòng</h5>
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Tên:</strong></td>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Mô tả:</strong></td>
                            <td>@Model.Description</td>
                        </tr>
                        <tr>
                            <td><strong>Số phòng:</strong></td>
                            <td>@Model.Rooms.Count</td>
                        </tr>
                    </table>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
                <button type="submit" class="btn btn-danger">Xóa loại phòng này</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>
</div>
